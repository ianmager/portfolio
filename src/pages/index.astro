---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../content/projects/project-data";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Ian Mager — Software Engineer">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="hero-greeting">Hi, I'm</p>
      <h1 class="hero-name">Ian Mager</h1>
      <h2 class="hero-role">Software Engineer</h2>
      <p class="hero-blurb">
        I build reliable software across the full stack, from data
        models to polished interfaces. I focus on clean architecture,
        thorough testing, and shipping work that holds up in production.
      </p>
      <div class="hero-actions">
        <a href={`${base}#projects`} class="btn btn-primary">View Projects</a>
        <a href={`${base}resume.pdf`} class="btn btn-outline" target="_blank" rel="noopener">
          Resume
        </a>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="section" id="projects">
    <div class="container">
      <h2 class="section-title">Featured Projects</h2>
      {projects.length > 0 ? (
        <div class="projects-grid">
          {projects.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>
      ) : (
        <p class="projects-empty">Projects coming soon.</p>
      )}
    </div>
  </section>

  <!-- Skills -->
  <section class="section" id="skills">
    <div class="container">
      <h2 class="section-title">Skills</h2>
      <div class="skills-grid">
        <div class="skill-group">
          <h3 class="skill-group-title">Languages</h3>
          <div class="skill-tags">
            <span class="tag">TypeScript</span>
            <span class="tag">JavaScript</span>
            <span class="tag">Python</span>
            <span class="tag">C</span>
            <span class="tag">C++</span>
          </div>
        </div>
        <div class="skill-group">
          <h3 class="skill-group-title">Frameworks & Libraries</h3>
          <div class="skill-tags">
            <span class="tag">React</span>
            <span class="tag">Next.js</span>
            <span class="tag">Node.js</span>
            <span class="tag">Express</span>
            <span class="tag">Astro</span>
          </div>
        </div>
        <div class="skill-group">
          <h3 class="skill-group-title">Tools & Infrastructure</h3>
          <div class="skill-tags">
            <span class="tag">Git</span>
            <span class="tag">Docker</span>
            <span class="tag">GitHub Actions</span>
            <span class="tag">Linux</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section" id="contact">
    <div class="container">
      <h2 class="section-title">Contact Me</h2>
      <p class="contact-text">
        I'm open to new opportunities and always happy to connect. Feel free to
        reach out via email or find me on the platforms below.
      </p>
      <div class="contact-links">
        <a href="mailto:MagerIan@outlook.com" class="contact-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
            <polyline points="22,6 12,13 2,6" />
          </svg>
          Email
        </a>
        <a href="https://github.com/ianmager" target="_blank" rel="noopener" class="contact-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
          </svg>
          GitHub
        </a>
        <a href="https://www.linkedin.com/in/ian-mager-9aa1323b8/" target="_blank" rel="noopener" class="contact-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
            <rect x="2" y="9" width="4" height="12" />
            <circle cx="4" cy="4" r="2" />
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 6rem 0 4rem;
  }

  .hero-greeting {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.25rem;
    letter-spacing: -0.03em;
  }

  .hero-role {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .hero-blurb {
    max-width: 540px;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-bg);
  }

  .btn-outline {
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
  }

  .btn-outline:hover {
    background: rgba(56, 189, 248, 0.1);
  }

  .projects-grid {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .skills-grid {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .skill-group-title {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .projects-empty {
    color: var(--color-text-muted);
    font-style: italic;
    font-size: 0.95rem;
  }

  .contact-text {
    color: var(--color-text-muted);
    max-width: 480px;
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  .contact-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .contact-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
